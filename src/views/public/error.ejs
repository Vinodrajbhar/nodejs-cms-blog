<%- include('../layouts/public_header') %>

<div class="max-w-lg mx-auto text-center py-24 px-4">
  <div class="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
    <i class="bi bi-exclamation-triangle text-red-500 text-4xl"></i>
  </div>
  <h1 class="text-3xl font-bold text-gray-900 mb-3"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
  <p class="text-gray-500 text-lg"><%= typeof message !== 'undefined' ? message : 'Something went wrong.' %></p>
  <a href="/" class="inline-block mt-8 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
    &larr; Back to Home
  </a>
</div>

<%- include('../layouts/public_footer') %>