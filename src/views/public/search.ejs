<%- include('../layouts/public_header') %>

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="max-w-xl mx-auto mb-12">
    <h1 class="text-3xl font-extrabold text-gray-900 text-center mb-6">Search</h1>
    <form action="/search" method="GET" class="flex gap-2">
      <input type="text" name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" placeholder="Search articles..." class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
      <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
        <i class="bi bi-search"></i>
      </button>
    </form>
  </div>

  <% if (typeof query !== 'undefined' && query) { %>
  <p class="text-sm text-gray-500 mb-8">
    <%= posts.length %> result<%= posts.length !== 1 ? 's' : '' %> for "<strong class="text-gray-700"><%= query %></strong>"
  </p>

  <% if (posts && posts.length) { %>
  <div class="space-y-6">
    <% posts.forEach(function(post) { %>
    <article class="bg-white border border-gray-100 rounded-xl p-6 hover:shadow-sm transition">
      <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
        <span><%= new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        <% if (post.categories && post.categories.length) { %>
        <span>&middot;</span>
        <% post.categories.forEach(function(cat) { %>
        <a href="<%= categoryUrl(cat) %>" class="text-blue-600 hover:underline"><%= cat.name %></a>
        <% }); %>
        <% } %>
      </div>
      <a href="<%= postUrl(post) %>" class="block">
        <h2 class="text-xl font-bold text-gray-900 hover:text-blue-600 transition"><%= post.title %></h2>
      </a>
      <% if (post.excerpt) { %>
      <p class="mt-2 text-sm text-gray-500"><%= post.excerpt.replace(/<[^>]*>/g, '') %></p>
      <% } else if (post.content) { %>
      <p class="mt-2 text-sm text-gray-500"><%= post.content.replace(/<[^>]*>/g, '').substring(0, 200) %></p>
      <% } %>
    </article>
    <% }); %>
  </div>

  <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
  <div class="flex items-center justify-center gap-2 mt-8">
    <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
    <a href="?q=<%= query %>&page=<%= currentPage - 1 %>" class="px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">&larr; Previous</a>
    <% } %>
    <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="?q=<%= query %>&page=<%= i %>" class="px-4 py-2 border rounded-lg text-sm <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-200 text-gray-600 hover:bg-gray-50' %>"><%= i %></a>
    <% } %>
    <% if (typeof currentPage !== 'undefined' && currentPage < totalPages) { %>
    <a href="?q=<%= query %>&page=<%= currentPage + 1 %>" class="px-4 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50">Next &rarr;</a>
    <% } %>
  </div>
  <% } %>
  <% } else { %>
  <div class="text-center py-16">
    <i class="bi bi-search text-gray-300 text-5xl block mb-4"></i>
    <h2 class="text-xl font-semibold text-gray-500">No results found</h2>
    <p class="text-gray-400 mt-2">Try different keywords or browse categories.</p>
  </div>
  <% } %>
  <% } %>
</section>

<%- include('../layouts/public_footer') %>