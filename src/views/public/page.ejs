<%- include('../layouts/public_header') %>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col lg:flex-row gap-12">
  <article class="flex-1 min-w-0 max-w-4xl">
    <div class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-blue-600 transition">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900"><%= page.title %></span>
    </div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6"><%= page.title %></h1>

    <div class="prose mx-auto">
      <%- page.content %>
    </div>
  </article>
  <!-- Sidebar -->
  <div class="w-full lg:w-72 flex-shrink-0">
    <%- include('partials/sidebar') %>
  </div>
</div>

<%- include('../layouts/public_footer') %>