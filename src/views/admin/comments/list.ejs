<%- include('../../layouts/admin_header') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Comments</h1>
</div>

<!-- Status tabs -->
<div class="flex items-center gap-2 mb-6">
  <a href="/admin/comments" class="px-3 py-1.5 rounded-lg text-sm font-medium transition <%= !filterStatus ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
    All (<%= pendingCount + approvedCount + spamCount %>)
  </a>
  <a href="/admin/comments?status=pending" class="px-3 py-1.5 rounded-lg text-sm font-medium transition <%= filterStatus === 'pending' ? 'bg-yellow-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
    Pending (<%= pendingCount %>)
  </a>
  <a href="/admin/comments?status=approved" class="px-3 py-1.5 rounded-lg text-sm font-medium transition <%= filterStatus === 'approved' ? 'bg-green-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
    Approved (<%= approvedCount %>)
  </a>
  <a href="/admin/comments?status=spam" class="px-3 py-1.5 rounded-lg text-sm font-medium transition <%= filterStatus === 'spam' ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
    Spam (<%= spamCount %>)
  </a>
</div>

<!-- Comments list -->
<div class="space-y-4">
  <% if (comments && comments.length) { %>
  <% comments.forEach(function(comment) { %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <div class="flex items-start justify-between">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="font-medium text-gray-900"><%= comment.author.name %></span>
          <span class="text-xs text-gray-400">&lt;<%= comment.author.email %>&gt;</span>
          <% if (comment.author.website) { %>
          <a href="<%= comment.author.website %>" target="_blank" rel="noopener" class="text-xs text-blue-600 hover:underline"><i class="bi bi-link-45deg"></i></a>
          <% } %>
          <span class="px-2 py-0.5 text-xs font-medium rounded
                <%= comment.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : '' %>
                <%= comment.status === 'approved' ? 'bg-green-100 text-green-700' : '' %>
                <%= comment.status === 'spam' ? 'bg-red-100 text-red-700' : '' %>">
            <%= comment.status %>
          </span>
        </div>
        <p class="text-sm text-gray-500 mt-1">
          On <a href="/post/<%= comment.post ? comment.post.slug : '#' %>" class="text-blue-600 hover:underline" target="_blank"><%= comment.post ? comment.post.title : '[deleted post]' %></a>
          &middot; <%= new Date(comment.createdAt).toLocaleString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
        </p>
        <div class="mt-3 text-sm text-gray-700 bg-gray-50 rounded-lg p-3"><%= comment.content %></div>
      </div>
    </div>
    <div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-100">
      <% if (comment.status !== 'approved') { %>
      <form action="/admin/comments/<%= comment._id %>/approve" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-green-50 text-green-700 rounded-lg hover:bg-green-100 transition flex items-center gap-1">
          <i class="bi bi-check-lg"></i> Approve
        </button>
      </form>
      <% } %>
      <% if (comment.status !== 'spam') { %>
      <form action="/admin/comments/<%= comment._id %>/spam" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition flex items-center gap-1">
          <i class="bi bi-flag"></i> Spam
        </button>
      </form>
      <% } %>
      <form action="/admin/comments/<%= comment._id %>/delete" method="POST" onsubmit="confirmDelete(event, 'Delete this comment?')" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="px-3 py-1.5 text-xs font-medium bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition flex items-center gap-1">
          <i class="bi bi-trash"></i> Delete
        </button>
      </form>
    </div>
  </div>
  <% }); %>
  <% } else { %>
  <div class="text-center py-16">
    <i class="bi bi-chat-dots text-gray-300 text-5xl block mb-4"></i>
    <p class="text-gray-500 text-lg">No comments found</p>
  </div>
  <% } %>
</div>

<%- include('../../layouts/admin_footer') %>