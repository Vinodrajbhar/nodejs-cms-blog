<%- include('../../layouts/admin_header') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Users</h1>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 flex items-center gap-2 text-sm">
  <i class="bi bi-exclamation-circle"></i> <%= error %>
</div>
<% } %>

<!-- Create user form -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-6">
  <h2 class="text-sm font-semibold text-gray-700 mb-3">Add New User</h2>
  <form action="/admin/users" method="POST" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 items-end">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div>
      <label for="username" class="block text-xs font-medium text-gray-500 mb-1">Username *</label>
      <input type="text" id="username" name="username" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="johndoe">
    </div>
    <div>
      <label for="email" class="block text-xs font-medium text-gray-500 mb-1">Email *</label>
      <input type="email" id="email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="john@example.com">
    </div>
    <div>
      <label for="password" class="block text-xs font-medium text-gray-500 mb-1">Password *</label>
      <input type="password" id="password" name="password" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Min 6 chars">
    </div>
    <div class="flex gap-2">
      <select name="role" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        <option value="author">Author</option>
        <option value="editor">Editor</option>
        <option value="admin">Admin</option>
      </select>
      <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-medium whitespace-nowrap">Add User</button>
    </div>
  </form>
</div>

<!-- Users table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-200">
        <th class="text-left px-4 py-3 font-medium text-gray-600">Username</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600 hidden md:table-cell">Email</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600">Role</th>
        <th class="text-left px-4 py-3 font-medium text-gray-600 hidden sm:table-cell">Joined</th>
        <th class="text-right px-4 py-3 font-medium text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (users && users.length) { %>
      <% users.forEach(function(user) { %>
      <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
        <td class="px-4 py-3 font-medium text-gray-900 flex items-center gap-2">
          <i class="bi bi-person-circle text-gray-400"></i> <%= user.username %>
          <% if (user._id.toString() === currentUser.id) { %>
          <span class="text-xs px-1.5 py-0.5 bg-blue-100 text-blue-600 rounded">you</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-gray-500 hidden md:table-cell"><%= user.email %></td>
        <td class="px-4 py-3">
          <% if (user._id.toString() === currentUser.id) { %>
          <span class="px-2 py-0.5 text-xs font-medium rounded bg-blue-100 text-blue-700 capitalize"><%= user.role %></span>
          <% } else { %>
          <form action="/admin/users/<%= user._id %>/role" method="POST" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <select name="role" onchange="this.form.submit()" class="text-xs border border-gray-300 rounded px-2 py-1 focus:ring-2 focus:ring-blue-500 outline-none">
              <option value="author" <%= user.role === 'author' ? 'selected' : '' %>>Author</option>
              <option value="editor" <%= user.role === 'editor' ? 'selected' : '' %>>Editor</option>
              <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </form>
          <% } %>
        </td>
        <td class="px-4 py-3 text-gray-500 text-xs hidden sm:table-cell"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
        <td class="px-4 py-3 text-right">
          <% if (user._id.toString() !== currentUser.id) { %>
          <form action="/admin/users/<%= user._id %>/delete" method="POST" onsubmit="confirmDelete(event, 'Delete user &quot;<%= user.username %>&quot;? All their posts will remain.')" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 transition" title="Delete"><i class="bi bi-trash"></i></button>
          </form>
          <% } else { %>
          <span class="text-xs text-gray-400">—</span>
          <% } %>
        </td>
      </tr>
      <% }); %>
      <% } else { %>
      <tr>
        <td colspan="5" class="text-center py-12 text-gray-400">
          <i class="bi bi-people text-3xl block mb-2"></i>
          <p>No users found</p>
        </td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../../layouts/admin_footer') %>