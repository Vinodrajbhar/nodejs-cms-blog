<%- include('../../layouts/admin_header') %>

<div class="max-w-5xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Themes</h1>
    <a href="/admin/themes/new" class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium text-sm flex items-center gap-2">
      <i class="bi bi-plus-lg"></i> Create New Theme
    </a>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
  <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4 flex items-center gap-2 text-sm">
    <i class="bi bi-check-circle"></i> <%= success %>
  </div>
  <% } %>

  <% if (typeof themes !== 'undefined' && themes.length) { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% themes.forEach(function(theme) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden <%= theme.isActive ? 'ring-2 ring-blue-500' : '' %>">
      <!-- Preview area -->
      <div class="h-36 bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center border-b border-gray-200 relative">
        <% if (theme.isActive) { %>
        <span class="absolute top-3 left-3 px-2.5 py-1 bg-blue-600 text-white text-xs font-semibold rounded-full flex items-center gap-1">
          <i class="bi bi-check-circle"></i> Active
        </span>
        <% } %>
        <div class="text-center">
          <i class="bi bi-palette text-4xl text-gray-300 block mb-1"></i>
          <span class="text-xs text-gray-400 font-mono"><%= theme.slug %></span>
        </div>
      </div>

      <!-- Info -->
      <div class="p-4">
        <h3 class="font-semibold text-gray-900 text-lg mb-1"><%= theme.name %></h3>
        <% if (theme.description) { %>
        <p class="text-sm text-gray-500 mb-3 line-clamp-2"><%= theme.description %></p>
        <% } %>
        <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
          <% if (theme.author) { %>
          <span class="flex items-center gap-1"><i class="bi bi-person"></i> <%= theme.author %></span>
          <% } %>
          <% if (theme.version) { %>
          <span class="flex items-center gap-1"><i class="bi bi-tag"></i> v<%= theme.version %></span>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-2 pt-3 border-t border-gray-100">
          <% if (!theme.isActive) { %>
          <form action="/admin/themes/<%= typeof theme._id !== 'undefined' && theme._id ? theme._id : '' %>/activate" method="POST" class="flex-1">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" <%= theme.source === 'filesystem' && (!theme._id) ? 'disabled' : '' %> class="w-full px-3 py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-xs font-medium <%= theme.source === 'filesystem' && (!theme._id) ? 'opacity-50 cursor-not-allowed' : '' %>">
              Activate
            </button>
          </form>
          <% } else { %>
          <span class="flex-1 text-center px-3 py-1.5 bg-blue-50 text-blue-600 rounded-lg text-xs font-medium">
            <i class="bi bi-check-circle"></i> Active
          </span>
          <% } %>

          <% if (theme._id) { %>
          <a href="/admin/themes/<%= theme._id %>/edit" class="px-3 py-1.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-xs">
            <i class="bi bi-pencil"></i>
          </a>
          <a href="/admin/themes/<%= theme._id %>/customize" class="px-3 py-1.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-xs">
            <i class="bi bi-code-slash"></i>
          </a>
          <form action="/admin/themes/<%= theme._id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete theme &quot;<%= theme.name %>&quot;? This will remove all theme files.');">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="px-3 py-1.5 border border-red-200 text-red-600 rounded-lg hover:bg-red-50 transition text-xs">
              <i class="bi bi-trash"></i>
            </button>
          </form>
          <% } else { %>
          <span class="px-3 py-1.5 text-xs text-gray-400 italic">Filesystem only</span>
          <% } %>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <!-- Empty state -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
    <div class="text-6xl text-gray-200 mb-4">
      <i class="bi bi-palette"></i>
    </div>
    <h3 class="text-lg font-semibold text-gray-700 mb-2">No themes yet</h3>
    <p class="text-sm text-gray-400 mb-6">Create your first theme to customize the look of your blog.</p>
    <a href="/admin/themes/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium text-sm">
      <i class="bi bi-plus-lg"></i> Create Your First Theme
    </a>
  </div>
  <% } %>
</div>

<%- include('../../layouts/admin_footer') %>