<%- include('../../layouts/admin_header') %>

<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= typeof theme !== 'undefined' && theme ? 'Edit Theme' : 'Create Theme' %></h1>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 flex items-center gap-2 text-sm">
    <i class="bi bi-exclamation-circle"></i> <%= error %>
  </div>
  <% } %>

  <form action="<%= typeof theme !== 'undefined' && theme ? '/admin/themes/' + theme._id + '/edit' : '/admin/themes' %>" method="POST" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-5">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Theme Name -->
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Theme Name <span class="text-red-500">*</span></label>
      <input type="text" id="name" name="name" value="<%= typeof theme !== 'undefined' && theme ? theme.name : '' %>" required class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm" placeholder="e.g. My Custom Theme">
      <p class="text-xs text-gray-400 mt-1">A slug will be generated from this name and used as the folder name.</p>
    </div>

    <!-- Description -->
    <div>
      <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <textarea id="description" name="description" rows="3" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm resize-y" placeholder="A short description of your theme"><%= typeof theme !== 'undefined' && theme ? theme.description : '' %></textarea>
    </div>

    <!-- Author -->
    <div>
      <label for="author" class="block text-sm font-medium text-gray-700 mb-1">Author</label>
      <input type="text" id="author" name="author" value="<%= typeof theme !== 'undefined' && theme ? theme.author : '' %>" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm" placeholder="Your name or organization">
    </div>

    <!-- Version -->
    <div>
      <label for="version" class="block text-sm font-medium text-gray-700 mb-1">Version</label>
      <input type="text" id="version" name="version" value="<%= typeof theme !== 'undefined' && theme ? theme.version : '1.0.0' %>" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none text-sm max-w-[160px]" placeholder="1.0.0">
    </div>

    <div class="pt-4 border-t border-gray-200 flex items-center gap-3">
      <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium text-sm">
        <i class="bi bi-check-lg"></i> <%= typeof theme !== 'undefined' && theme ? 'Save Changes' : 'Create Theme' %>
      </button>
      <a href="/admin/themes" class="px-6 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition text-sm">
        Cancel
      </a>
    </div>
  </form>
</div>

<%- include('../../layouts/admin_footer') %>