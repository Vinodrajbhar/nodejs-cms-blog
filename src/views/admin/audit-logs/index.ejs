<%- include('../../layouts/admin_header') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Audit Logs</h1>
  <span class="text-sm text-gray-500"><%= total %> log<%= total !== 1 ? 's' : '' %></span>
</div>

<!-- Filters -->
<form method="GET" action="/admin/audit-logs" class="flex flex-wrap items-center gap-3 mb-6">
  <select name="action" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
    <option value="">All actions</option>
    <% actions.forEach(function(a) { %>
    <option value="<%= a %>" <%= filterAction === a ? 'selected' : '' %>><%= a %></option>
    <% }); %>
  </select>
  <select name="entity" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
    <option value="">All entities</option>
    <% entities.forEach(function(e) { %>
    <option value="<%= e %>" <%= filterEntity === e ? 'selected' : '' %>><%= e %></option>
    <% }); %>
  </select>
  <button type="submit" class="px-3 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition text-sm">Filter</button>
  <% if (filterAction || filterEntity) { %>
  <a href="/admin/audit-logs" class="px-3 py-2 text-sm text-gray-500 hover:text-gray-700">Clear</a>
  <% } %>
</form>

<!-- Logs table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="text-left px-4 py-3 font-medium text-gray-600">Time</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Action</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Entity</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600 hidden md:table-cell">Description</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600 hidden lg:table-cell">By</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600 hidden lg:table-cell">IP</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs && logs.length) { %>
        <% logs.forEach(function(log) { %>
        <tr class="border-b border-gray-100 hover:bg-gray-50 transition">
          <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">
            <%= new Date(log.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
          </td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 text-xs font-medium rounded
              <%= log.action === 'delete' ? 'bg-red-100 text-red-700' : '' %>
              <%= log.action === 'create' || log.action === 'upload' ? 'bg-green-100 text-green-700' : '' %>
              <%= log.action === 'update' || log.action === 'approve' ? 'bg-blue-100 text-blue-700' : '' %>
              <%= log.action === 'login' || log.action === 'logout' ? 'bg-gray-100 text-gray-600' : '' %>
              <%= log.action === 'spam' ? 'bg-yellow-100 text-yellow-700' : '' %>
            "><%= log.action %></span>
          </td>
          <td class="px-4 py-3 text-gray-700"><%= log.entity %></td>
          <td class="px-4 py-3 text-gray-500 text-xs hidden md:table-cell max-w-xs truncate" title="<%= log.description %>"><%= log.description %></td>
          <td class="px-4 py-3 text-gray-500 text-xs hidden lg:table-cell"><%= log.performerName %></td>
          <td class="px-4 py-3 text-gray-400 text-xs hidden lg:table-cell font-mono"><%= log.ip %></td>
        </tr>
        <% }); %>
        <% } else { %>
        <tr>
          <td colspan="6" class="text-center py-12 text-gray-400">
            <i class="bi bi-journal-text text-3xl block mb-2"></i>
            <p>No audit logs found</p>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<div class="flex items-center justify-center gap-2 mt-6">
  <% if (currentPage > 1) { %>
  <a href="?page=<%= currentPage - 1 %><%= filterAction ? '&action=' + filterAction : '' %><%= filterEntity ? '&entity=' + filterEntity : '' %>" class="px-3 py-1.5 border border-gray-200 rounded text-sm text-gray-600 hover:bg-gray-50 transition">&larr;</a>
  <% } %>
  <% for (let i = 1; i <= totalPages; i++) { %>
  <a href="?page=<%= i %><%= filterAction ? '&action=' + filterAction : '' %><%= filterEntity ? '&entity=' + filterEntity : '' %>" class="px-3 py-1.5 border rounded text-sm <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-200 text-gray-600 hover:bg-gray-50' %>"><%= i %></a>
  <% } %>
  <% if (currentPage < totalPages) { %>
  <a href="?page=<%= currentPage + 1 %><%= filterAction ? '&action=' + filterAction : '' %><%= filterEntity ? '&entity=' + filterEntity : '' %>" class="px-3 py-1.5 border border-gray-200 rounded text-sm text-gray-600 hover:bg-gray-50 transition">&rarr;</a>
  <% } %>
</div>
<% } %>

<%- include('../../layouts/admin_footer') %>